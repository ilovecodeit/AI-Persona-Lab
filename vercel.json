{
  "version": 2,
  "builds": [
    {
      "src": "api/gemini/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/gemini/persona-chat",
      "dest": "/api/gemini/persona-chat.ts"
    },
    {
      "src": "/api/gemini/explain-concept",
      "dest": "/api/gemini/explain-concept.ts"
    },
    {
      "src": "/api/gemini/co-write",
      "dest": "/api/gemini/co-write.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "dist/index.html"
    }
  ]
}
